---
---
<div class="not-found">
  <div class="terminal">
    <div class="terminal-bar">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
      <span class="terminal-title">tamad</span>
    </div>
    <div class="terminal-body">
      <p class="line"><span class="prompt">$</span> tamar <span class="arg">"follow this path"</span></p>
      <p class="line error">✗ agent route not found</p>
      <p class="line muted">  pattern : oneshot</p>
      <p class="line muted">  status  : <span class="badge-err">404</span></p>
      <p class="line muted">  hint    : the page you requested does not exist</p>
      <p class="line"><span class="cursor">▌</span></p>
    </div>
  </div>
  <div class="actions-row">
    <a href="/" class="btn primary">Go home</a>
    <a href="/getting-started/introduction" class="btn secondary">Getting started</a>
  </div>
</div>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding: 3rem 1rem;
  }

  .terminal {
    width: 100%;
    max-width: 540px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    font-family: 'DM Mono', monospace;
    font-size: 13px;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .terminal-title {
    margin-left: auto;
    margin-right: auto;
    font-size: 12px;
    color: var(--sl-color-gray-3);
    letter-spacing: 0.04em;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot.red    { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green  { background: #28c840; }

  .terminal-body {
    padding: 1.25rem 1.5rem;
    background: var(--sl-color-bg);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .line {
    margin: 0;
    line-height: 1.7;
    color: var(--sl-color-text);
  }

  .prompt {
    color: #0ea5e9;
    margin-right: 0.5ch;
    font-weight: 500;
  }

  .arg { color: #d946ef; }

  .error {
    color: #dc2626;
    font-weight: 500;
    margin-top: 6px;
  }

  .muted {
    color: var(--sl-color-gray-3);
    padding-left: 2ch;
  }

  .badge-err {
    background: #fee2e2;
    color: #dc2626;
    border-radius: 3px;
    padding: 1px 6px;
    font-size: 11px;
    font-weight: 600;
  }

  :root[data-theme='dark'] .badge-err {
    background: #3b0a0a;
    color: #f87171;
  }

  .cursor {
    color: #0ea5e9;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .actions-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    display: inline-block;
    padding: 0.5rem 2rem;
    border-radius: 4px;
    font-family: 'Rethink Sans', sans-serif;
    font-weight: 500;
    font-size: 14px;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .btn.primary {
    border: 2px solid #0ea5e9;
    color: #111827;
    background: #ffffff;
  }
  .btn.primary:hover { background: #f0f9ff; }

  .btn.secondary {
    border: 2px solid #d946ef;
    color: #111827;
    background: transparent;
  }
  .btn.secondary:hover { background: #fdf4ff; }

  :root[data-theme='dark'] .btn.primary {
    background: transparent;
    border-color: #38bdf8;
    color: #e2e8f0;
  }
  :root[data-theme='dark'] .btn.primary:hover { background: #082f49; }

  :root[data-theme='dark'] .btn.secondary {
    border-color: #d946ef;
    color: #e2e8f0;
  }
  :root[data-theme='dark'] .btn.secondary:hover { background: #2d0a35; }
</style>
